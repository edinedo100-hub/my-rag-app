rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Users can fully read and write their own profile.
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Any authenticated user can READ any profile (needed to look up referral codes).
      allow read: if request.auth != null;

      // Any authenticated user can credit another user's balance (referral reward).
      // We restrict this to ONLY incrementing balance — no other fields may change.
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['balance']);

      // Notifications sub-collection
      match /notifications/{notificationId} {
        // Users can read/write their own notifications.
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Any authenticated user can CREATE a notification for another user
        // (e.g., "Referral Success!" message sent to a referrer).
        allow create: if request.auth != null;
      }
    }

    // Authenticated users can read/write their own uploads.
    match /uploads/{uploadId} {
      allow read: if request.auth != null
                  && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }
  }
}
